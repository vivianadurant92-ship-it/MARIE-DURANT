# ── Servidor (Vercel) ──────────────────────────────────────────
# Agrega esta variable en Vercel Dashboard → Settings → Environment Variables
ANTHROPIC_API_KEY=sk-ant-...

# ── Frontend (Vite) ────────────────────────────────────────────
# Vacío para web/Vercel (usa URL relativa /api/chat).
# Para builds de Capacitor (Android/iOS), pon la URL de tu deploy:
#   VITE_API_BASE_URL=https://nutricoach-app.vercel.app
VITE_API_BASE_URL=
